# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter — gateway for many models (Llama, DeepSeek, GPT, Gemini, Claude, etc.)
# Get key: openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# App attribution (optional, shown on openrouter.ai/activity)
OPENROUTER_REFERER=https://clientlens.example.com
OPENROUTER_TITLE=ClientLens

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Pinecone
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX=clientlens

# Deepgram STT — key stays server-side, never in the extension bundle.
# Project ID: https://console.deepgram.com → Settings → Projects
DEEPGRAM_API_KEY=
DEEPGRAM_PROJECT_ID=

# Google OAuth (for Slides/Docs API)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Zoho CRM OAuth — client_secret stays server-side, never in the extension bundle.
# The extension proxies all token exchanges through /api/v1/zoho/{exchange,refresh}.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=

# App
BACKEND_URL=https://your-backend.railway.app
ALLOWED_ORIGINS=chrome-extension://YOUR_EXTENSION_ID,http://localhost:3000
JWT_SECRET=change-me-in-production
