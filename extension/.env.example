# ─── PREVIEW MODE ──────────────────────────────────────────────────────────────
VITE_MOCK_MODE=true

# ─── LLM PROVIDER ──────────────────────────────────────────────────────────────
# "gemini" | "groq" | "anthropic"
VITE_LLM_PROVIDER=gemini

# Google Gemini (free tier: 1500 req/day, 1M tokens/min on Flash). aistudio.google.com/apikey
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
VITE_GEMINI_MODEL=gemini-2.0-flash

# Groq (free, fast, Llama 3.3 70B). console.groq.com
VITE_GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# Anthropic (paid). console.anthropic.com
VITE_ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# ─── PRODUCTION (fill in after backend is deployed) ────────────────────────────
VITE_BACKEND_URL=http://localhost:8000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
