# ─── PREVIEW MODE ──────────────────────────────────────────────────────────────
# Set to true to use mock responses for UI dev. As of issue #1, mock mode for
# Anthropic still routes through the FastAPI backend (`/api/v1/llm/complete`)
# rather than calling the SDK directly — so the backend must be reachable at
# VITE_BACKEND_URL when MOCK_MODE=true. Pure offline UI dev (no LLM at all)
# is not currently supported; track in a follow-up if you need it.
VITE_MOCK_MODE=true

# ─── LLM PROVIDER ──────────────────────────────────────────────────────────────
# "gemini" | "groq" | "anthropic" | "openrouter" | "custom"
VITE_LLM_PROVIDER=gemini

# Google Gemini (generous free tier). Get key: aistudio.google.com/apikey
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
VITE_GEMINI_MODEL=gemini-2.0-flash

# Groq (free, very fast Llama 3.3 70B). Get key: console.groq.com/keys
VITE_GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# Anthropic Claude is routed through the FastAPI backend (`/api/v1/llm/*`).
# DO NOT set VITE_ANTHROPIC_API_KEY here — the extension never holds an Anthropic key.
# The backend's ANTHROPIC_API_KEY env var is the only place the key should live.
# (Closes #1.)

# OpenRouter is also routed through the backend (`/api/v1/llm/*`).
# DO NOT set an OpenRouter API key here. Set OPENROUTER_API_KEY in backend/.env.
# Optional: override the default model picked when provider=openrouter.
# VITE_OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ─── PRESET KEYS (optional — loaded as default values in Settings UI) ───────────
# If set, these are pre-filled as the default provider key. Users can override
# them from the Settings panel. Leave blank to require users to enter their own.
VITE_GEMINI_PRESET_KEY=
VITE_GROQ_PRESET_KEY=

# ─── TEAM AUTH ─────────────────────────────────────────────────────────────────
# Google Workspace domain whose accounts are allowed to sign in.
# Only emails ending in @<domain> can use the extension.
# Change this to your org's domain before distributing the extension.
VITE_ALLOWED_DOMAIN=example.com

# ─── PRODUCTION (fill in after backend is deployed) ────────────────────────────
VITE_BACKEND_URL=http://localhost:8000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
